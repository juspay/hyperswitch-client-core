let paybybank = `<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none"><path d="M11.9997 7.71422C12.3406 7.71422 12.6677 7.57876 12.9088 7.33765C13.1499 7.09653 13.2854 6.7695 13.2854 6.42851C13.2854 6.08751 13.1499 5.76049 12.9088 5.51937C12.6677 5.27825 12.3406 5.14279 11.9997 5.14279C11.6587 5.14279 11.3316 5.27825 11.0905 5.51937C10.8494 5.76049 10.7139 6.08751 10.7139 6.42851C10.7139 6.7695 10.8494 7.09653 11.0905 7.33765C11.3316 7.57876 11.6587 7.71422 11.9997 7.71422ZM12.7625 1.96708C12.5415 1.80419 12.2742 1.71631 11.9997 1.71631C11.7251 1.71631 11.4578 1.80419 11.2368 1.96708L3.09394 7.97136C2.09623 8.70765 2.61651 10.2916 3.8568 10.2916H4.28537V16.4991C3.77757 16.7107 3.34379 17.0679 3.03871 17.5256C2.73363 17.9834 2.57091 18.5212 2.57108 19.0714V20.3571C2.57108 20.7119 2.85908 20.9999 3.21394 20.9999H20.7854C20.9559 20.9999 21.1194 20.9322 21.2399 20.8116C21.3605 20.6911 21.4282 20.5276 21.4282 20.3571V19.0714C21.4282 18.5214 21.2654 17.9837 20.9604 17.5261C20.6553 17.0685 20.2216 16.7115 19.7139 16.4999V10.2916H20.1417C21.3828 10.2916 21.9031 8.70765 20.9045 7.97136L12.7625 1.96708ZM5.57108 16.2857V10.2916H7.71394V16.2857H5.57108ZM18.4282 10.2916V16.2857H16.2854V10.2916H18.4282ZM14.9997 10.2916V16.2857H12.6425V10.2916H14.9997ZM11.3568 10.2916V16.2857H8.99966V10.2916H11.3568ZM3.8568 9.00594L11.9997 3.00165L20.1417 9.00594H3.8568ZM3.8568 19.0714C3.8568 18.2434 4.5288 17.5714 5.3568 17.5714H18.6425C19.4705 17.5714 20.1425 18.2434 20.1425 19.0714V19.7142H3.8568V19.0714Z"/></svg>`

type uri = {
  uri: string,
  local: bool,
}

open ReactNative
open Style

module Icon = {
  @react.component
  let make = (
    ~name,
    ~width=20.,
    ~height=16.,
    ~fill="#ffffff",
    ~stroke=?,
    ~style=empty,
    ~fallbackIcon: option<string>=?,
  ) => {
    let getIconName = name =>
      name
      ->String.replaceRegExp(%re("/ /g"), "")
      ->String.replaceAll("/", "")
      ->String.replaceAll("|", "")
      ->String.toLowerCase

    let (iconName, setIconName) = React.useState(_ => name->getIconName)

    React.useEffect1(() => {
      let newIconName = name->getIconName
      if newIconName !== iconName {
        setIconName(_ => newIconName)
      }
      None
    }, [name])

    let getAssetUrl = GlobalHooks.useGetAssetUrlWithVersion()

    let uri = React.useMemo1(() => {
      let assetUrl = `${getAssetUrl()}/images/error.svg`

      let localName = switch iconName {
      | "error" => ReactNativeSvg.error
      | "card" => card
      | "cardv1" => cardv1
      | "close" => close
      | "cvv" => cvv
      | "lock" => lock
      | "waitcard" => waitcard
      | "camera" => camera
      | "addwithcircle" => addwithcircle
      | "checkboxclicked" => checkboxclicked
      | "checkboxnotclicked" => checkboxnotclicked
      | "defaulttick" => defaultTick
      | "googlepay" => googlePay
      | "applepay" => applePayList
      | "disclaimer" => disclaimericon
      | "add" => add
      | "saved" => saved
      | "visa" => visa
      | "mastercard" => mastercard
      | "americanexpress" => americanexpress
      | "dinersclub" => dinersclub
      | "discover" => discover
      | "jcb" => jcb
      | "chevron" => chevron
      | "selected" => selected
      | "reload" => reload
      | "brokenrobot" => brokenrobot
      | "paybybank" => paybybank
      | _ => ""
      }
      localName == ""
        ? {
            uri: assetUrl->String.replace("error", iconName),
            local: false,
          }
        : {uri: localName, local: true}
    }, [iconName])

    <View style={array([s({height: height->dp, width: width->dp}), style])}>
      {uri.local
        ? <ReactNativeSvg.SvgCss
            onError={() => {
              setIconName(_ => fallbackIcon->Option.getOr("error"))
            }}
            xml=uri.uri
            width
            height
            fill
            color=?stroke
          />
        : <ReactNativeSvg.SvgUri
            onError={() => {
              setIconName(_ => fallbackIcon->Option.getOr("error"))
            }}
            uri=uri.uri
            width
            height
            fill
            loadingComponent={<ActivityIndicator
              style={s({height: height->dp, width: width->dp})} color=fill
            />}
          />}
    </View>
  }
}

let make = React.memoCustomCompareProps(Icon.make, (oldProps, newProps) =>
  oldProps.name === newProps.name && oldProps.fill === newProps.fill
)
